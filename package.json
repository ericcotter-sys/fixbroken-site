{
  "name": "vumo-fixbroken-site",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "main": "server.js",
  "bin": {
    "fb": "bin/fb"
  },
  "scripts": {
    "start": "node server.js",
    "lint:voice": "node tools/voice-lint.js",
    "lint:voice:json": "node tools/voice-lint.js --json",
    "lint:voice:strict": "node tools/voice-lint.js --strict",
    "generate:manifest": "node tools/generate-manifest.js",
    "generate:styleguide": "node tools/generate-styleguide.js",
    "generate": "node tools/generate-manifest.js && node tools/generate-styleguide.js",
    "scaffold": "node tools/scaffold-tenant.js",
    "audit": "node tools/audit.js",
    "audit:json": "node tools/audit.js --json",
    "audit:verbose": "node tools/audit.js --verbose",
    "validate:manifest": "node tools/validate-manifest.js",
    "check": "node tools/check.js",
    "check:fix": "node tools/check.js --fix",
    "tenants": "node tools/tenants.js",
    "tenants:health": "node tools/tenants.js --health",
    "diff:tokens": "node tools/token-diff.js",
    "changelog": "node tools/changelog.js",
    "changelog:md": "node tools/changelog.js --markdown",
    "deploy:check": "node tools/deploy-check.js",
    "deploy:verify": "node tools/deploy-check.js --post",
    "usage": "node tools/usage.js",
    "usage:all": "node tools/usage.js --all",
    "usage:unused": "node tools/usage.js --unused",
    "contrast": "node tools/contrast.js",
    "contrast:failures": "node tools/contrast.js --fail-only",
    "validate:overrides": "node tools/validate-overrides.js"
  },
  "dependencies": {
    "connect-pg-simple": "^10.0.0",
    "express": "^4.21.0",
    "express-session": "^1.19.0",
    "nodemailer": "^6.9.14",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "pg-mem": "^3.0.14"
  }
}
